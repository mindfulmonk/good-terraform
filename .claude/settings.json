{
  "permissions": {
    "allow": [
      "Bash(terraform fmt*)",
      "Bash(terraform validate*)",
      "Bash(terraform plan*)",
      "Bash(pre-commit run*)",
      "Bash(gcloud auth application-default login)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ],
    "deny": [
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(git push --force*)",
      "Bash(rm -rf*)"
    ]
  }
}
